{
  "_comment": "A lean 'recruiter card': only the essentials, provenance and confidence off, missing fields omitted entirely (on_missing=omit) so the output stays tidy.",
  "fields": [
    { "path": "name", "from": "full_name", "type": "string", "required": true },
    { "path": "email", "from": "emails[0]", "type": "string" },
    { "path": "phone", "from": "phones[0]", "type": "string", "normalize": "E164" },
    { "path": "headline", "from": "headline", "type": "string" },
    { "path": "github", "from": "links.github", "type": "string" }
  ],
  "include_confidence": false,
  "include_provenance": false,
  "on_missing": "omit"
}
